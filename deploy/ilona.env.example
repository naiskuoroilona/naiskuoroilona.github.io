# Reference only — deploy/install.sh creates /etc/ilona.env on first run
# with a random ADMIN_PASS, and deploy/set-admin-password.sh updates it.
#
# This file is read by systemd (EnvironmentFile=) — no `export`,
# one KEY=VALUE per line. Values with spaces or special chars should be
# wrapped in single quotes.

NODE_ENV=production
HOST=127.0.0.1
PORT=3000

ADMIN_USER=admin
ADMIN_PASS=change-me-to-something-long-and-random
